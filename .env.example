# =====================================================
# Application
# =====================================================

APP_NAME=Quran Bot
DEBUG=false
LOG_LEVEL=INFO



# =====================================================
# Telegram / Bale Bot
# =====================================================

BOT_TOKEN=YOUR_BOT_TOKEN

# Telegram:
# BOT_API=https://api.telegram.org/

# Bale:
BOT_API=https://tapi.bale.ai/



# =====================================================
# Database
# =====================================================

DATABASE_URL=postgresql://user:password@postgres:5432/natiq



# =====================================================
# Redis
# =====================================================

REDIS_URL=redis://redis:6379/0



# =====================================================
# Natiq API
# =====================================================

NATIQ_API_URL=https://api.natiq.net

NATIQ_API_TIMEOUT=30



# =====================================================
# Quran Source
# =====================================================

# Mushaf UUID or API identifier if required
# Keep this configurable.
#
# Example:
# hafs
# uthmani

QURAN_MUSHAF=hafs



# =====================================================
# Translation
# =====================================================

# Translation language selector.
#
# This is NOT a UUID.
#
# Provider will:
#
# 1. Load /translations/
# 2. Find matching language
# 3. Extract UUID
# 4. Load translation ayahs
#
# Examples:
#
# fa
# en
# tr
# ar

QURAN_TRANSLATION_LANGUAGE=fa



# =====================================================
# Cache
# =====================================================

CACHE_ENABLED=true



# =====================================================
# Docker
# =====================================================

TZ=UTC
